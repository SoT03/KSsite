// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      String   @default("user") // "admin" or "user"
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  openedBoxes BoxOpening[]
}

model Message {
  id        String   @id @default(cuid())
  year      Int // Which year's feature this belongs to (2026, 2027, etc.)
  dayNumber Int // Day 1-365
  content   String // "for your smile", etc.
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  openedBoxes BoxOpening[]

  @@unique([year, dayNumber])
}

model BoxOpening {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  messageId String
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  openedAt  DateTime @default(now())

  @@unique([userId, messageId])
}

model AnniversaryDate {
  id        String   @id @default(cuid())
  date      DateTime // Your anniversary date
  updatedAt DateTime @updatedAt
}
